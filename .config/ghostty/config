font-family = "FiraCode Nerd Font"
theme = dark:nightfox
font-size = 16
mouse-hide-while-typing = true
macos-option-as-alt = true

macos-titlebar-style = tabs

shell-integration=zsh

background-opacity = 0.85
background-blur-radius = 10

cursor-style-blink = true

confirm-close-surface = false
copy-on-select = clipboard
keybind = shift+enter=text:\x1b\r

keybind = cmd+h=goto_split:left
keybind = cmd+j=goto_split:bottom
keybind = cmd+k=goto_split:top
keybind = cmd+l=goto_split:right

keybind = alt+a>h=new_split:left
keybind = alt+a>j=new_split:down
keybind = alt+a>k=new_split:up
keybind = alt+a>l=new_split:right
keybind = alt+a>f=toggle_split_zoom

keybind = alt+a>n=next_tab
keybind = alt+a>p=previous_tab

# Quick terminal
keybind = global:cmd+grave_accent=toggle_quick_terminal
quick-terminal-size=80%

# Save window state
window-save-state=always
